{
  "name": "shi-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "逝爱 - 保存那些美好的回忆",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite --port 5173",
    "dev:backend": "cd backend && python -m uvicorn app:app --host 0.0.0.0 --port 18000 --reload",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "install:all": "npm install && cd backend && pip install -r requirements.txt"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.1.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  }
}
